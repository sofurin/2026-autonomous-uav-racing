<?xml version="1.0"?>
<sdf version="1.9">
  <model name="team_racer">
    <!-- Raise base_link so the CAD lower bound touches z=0 at the default pose. -->
    <pose>0 0 0.06756394 0 0 0</pose>
    <self_collide>false</self_collide>

    <link name="base_link">
      <!-- Temporary PX4 gz_x500 dynamics baseline; not measured flight truth. -->
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0216666667</ixx>
          <iyy>0.0216666667</iyy>
          <izz>0.0400000000</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <visual name="team_cad_visual">
        <!-- SolidWorks Y-up -> ROS/Gazebo FLU. -->
        <pose>0 0 0 1.57079632679 0 1.57079632679</pose>
        <geometry>
          <mesh>
            <uri>model://team_racer/meshes/base_link.stl</uri>
          </mesh>
        </geometry>
        <material>
          <diffuse>0.34 0.38 0.42 1</diffuse>
          <specular>0.12 0.12 0.12 1</specular>
        </material>
      </visual>

      <!-- Primitive-only collision geometry keeps contact simulation cheap. -->
      <collision name="central_stack_collision">
        <pose>-0.0070725679 0.0137969405 -0.0000639409 0 0 0</pose>
        <geometry>
          <box><size>0.13 0.12 0.13</size></box>
        </geometry>
      </collision>
      <collision name="front_right_to_rear_left_arm_collision">
        <pose>-0.0062722581 0.0047383578 -0.01 0 0 -0.7853981634</pose>
        <geometry>
          <box><size>0.25 0.025 0.015</size></box>
        </geometry>
      </collision>
      <collision name="front_left_to_rear_right_arm_collision">
        <pose>-0.0062722581 0.0047383578 -0.01 0 0 0.7853981634</pose>
        <geometry>
          <box><size>0.25 0.025 0.015</size></box>
        </geometry>
      </collision>

      <!-- Names and parent link match the PX4 gz_bridge x500 sensor contract. -->
      <sensor name="air_pressure_sensor" type="air_pressure">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <air_pressure/>
      </sensor>
      <sensor name="magnetometer_sensor" type="magnetometer">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <magnetometer/>
      </sensor>
      <sensor name="imu_sensor" type="imu">
        <pose>0 0 0.02 0 0 0</pose>
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>250</update_rate>
        <imu/>
      </sensor>
      <sensor name="navsat_sensor" type="navsat">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>10</update_rate>
        <navsat/>
      </sensor>
    </link>

    <link name="flight_controller_link">
      <pose relative_to="base_link">0 0 0.02 0 0 0</pose>
      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>0.0000001</ixx><iyy>0.0000001</iyy><izz>0.0000001</izz>
        </inertia>
      </inertial>
    </link>
    <joint name="flight_controller_joint" type="fixed">
      <parent>base_link</parent>
      <child>flight_controller_link</child>
    </joint>

    <link name="imu_link">
      <pose relative_to="base_link">0 0 0.02 0 0 0</pose>
      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>0.0000001</ixx><iyy>0.0000001</iyy><izz>0.0000001</izz>
        </inertia>
      </inertial>
    </link>
    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent>
      <child>imu_link</child>
    </joint>

    <!-- Rotor positions are CAD-derived ROS FLU coordinates. Propeller contact
         is intentionally disabled; only each motor hub has a cylinder collision. -->
    <link name="rotor_0">
      <pose relative_to="base_link">0.0821160896 -0.0836499899 -0.02486394 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia><ixx>9.75e-07</ixx><iyy>0.000273104</iyy><izz>0.000274004</izz></inertia>
      </inertial>
      <collision name="motor_hub_collision">
        <pose>0 0 0.0213 0 0 0</pose>
        <geometry><cylinder><radius>0.015</radius><length>0.03</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent><child>rotor_0</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <link name="rotor_1">
      <pose relative_to="base_link">-0.0946606057 0.0931267054 -0.02486394 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia><ixx>9.75e-07</ixx><iyy>0.000273104</iyy><izz>0.000274004</izz></inertia>
      </inertial>
      <collision name="motor_hub_collision">
        <pose>0 0 0.0213 0 0 0</pose>
        <geometry><cylinder><radius>0.015</radius><length>0.03</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent><child>rotor_1</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <link name="rotor_2">
      <pose relative_to="base_link">0.0821160896 0.0931267054 -0.02486394 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia><ixx>9.75e-07</ixx><iyy>0.000273104</iyy><izz>0.000274004</izz></inertia>
      </inertial>
      <collision name="motor_hub_collision">
        <pose>0 0 0.0213 0 0 0</pose>
        <geometry><cylinder><radius>0.015</radius><length>0.03</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent><child>rotor_2</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <link name="rotor_3">
      <pose relative_to="base_link">-0.0946606057 -0.0836499899 -0.02486394 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia><ixx>9.75e-07</ixx><iyy>0.000273104</iyy><izz>0.000274004</izz></inertia>
      </inertial>
      <collision name="motor_hub_collision">
        <pose>0 0 0.0213 0 0 0</pose>
        <geometry><cylinder><radius>0.015</radius><length>0.03</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="rotor_3_joint" type="revolute">
      <parent>base_link</parent><child>rotor_3</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <!-- Motor coefficients remain the PX4 gz_x500 baseline until bench tests. -->
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_0_joint</jointName><linkName>rotor_0</linkName>
      <turningDirection>ccw</turningDirection><timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown><maxRotVelocity>1000</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant><momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic><motorNumber>0</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/0</motorSpeedPubTopic><rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_1_joint</jointName><linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection><timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown><maxRotVelocity>1000</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant><momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic><motorNumber>1</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/1</motorSpeedPubTopic><rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_2_joint</jointName><linkName>rotor_2</linkName>
      <turningDirection>cw</turningDirection><timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown><maxRotVelocity>1000</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant><momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic><motorNumber>2</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/2</motorSpeedPubTopic><rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_3_joint</jointName><linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection><timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown><maxRotVelocity>1000</maxRotVelocity>
      <motorConstant>8.54858e-06</motorConstant><momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic><motorNumber>3</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/3</motorSpeedPubTopic><rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
  </model>
</sdf>
