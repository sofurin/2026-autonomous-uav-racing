<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="racing_uav">
  <!-- CAD D435 component frame; refine with measured optical extrinsics. -->
  <xacro:arg name="camera_xyz" default="-0.0085553439 -0.0652616422 0.0549360600"/>
  <xacro:arg name="camera_rpy" default="0 0 0"/>

  <!-- The detailed CAD mesh is visualization-only. Flight dynamics remain PX4-owned. -->
  <link name="base_link">
    <visual name="team_airframe_visual">
      <!-- Map SolidWorks Y-up axes to ROS X-forward, Y-left, Z-up axes. -->
      <origin xyz="0 0 0" rpy="1.57079632679 0 1.57079632679"/>
      <geometry>
        <mesh
          filename="package://racing_description/meshes/team_racer/base_link.stl"
          scale="1 1 1"/>
      </geometry>
      <material name="team_racer_gold">
        <color rgba="0.64706 0.51765 0 1"/>
      </material>
    </visual>
  </link>
  <link name="camera_link"/>
  <link name="camera_optical_frame"/>

  <joint name="base_to_camera" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="$(arg camera_xyz)" rpy="$(arg camera_rpy)"/>
  </joint>

  <joint name="camera_to_optical" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>
</robot>
