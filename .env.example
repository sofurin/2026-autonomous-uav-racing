COMPOSE_PROJECT_NAME=uav-racing
RACING_UID=1000
RACING_GID=1000
ROS_DOMAIN_ID=0
DISPLAY=:0

# The environment never starts a real-flight launch by itself. Keep the serial
# device empty until a flight controller is identified through /dev/serial/by-id.
PX4_XRCE_TRANSPORT=serial
PX4_XRCE_UDP_PORT=8888
PX4_SERIAL_DEVICE=
PX4_SERIAL_BAUD=921600
